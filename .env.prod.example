# =============================================================================
# .env.prod.example  —  운영 환경 변수 템플릿
#
# 사용법:
#   cp .env.prod.example .env.prod
#   vi .env.prod   # 실제 값으로 교체
#
# ⚠️  .env.prod 는 절대 Git 에 커밋하지 마세요.
#     .gitignore 에 .env.prod 가 포함되어 있는지 확인하세요.
# =============================================================================


# ── 데이터베이스 ─────────────────────────────────────────────────────────────────
# docker-compose.prod.yml 의 db 서비스와 일치해야 함
DB_HOST=db
DB_PORT=5432
DB_NAME=skbs_it_report
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ⚠️  DATABASE_URL 은 위의 개별 변수를 조합하여 직접 작성합니다.
# 형식: postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/skbs_it_report


# ── CORS (운영 서버 도메인/IP) ────────────────────────────────────────────────────
# Nginx 를 통해 서비스되는 프론트엔드 URL (복수 도메인은 쉼표로 구분)
# 예시: https://it-report.skbs.co.kr 또는 http://192.168.1.100
CORS_ORIGIN=http://YOUR_SERVER_IP_OR_DOMAIN


# ── JWT 인증 ─────────────────────────────────────────────────────────────────────
# 최소 32자 이상의 무작위 문자열 권장
# 생성 예시: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=24h


# ── 외부 시스템 연동 (사업부별 시스템 계정) ─────────────────────────────────────────
# Bio연구본부
BIO_ERP_USER=
BIO_ERP_PASS=
BIO_MES_USER=
BIO_MES_PASS=

# 개발본부
DEV_GITLAB_TOKEN=
DEV_JIRA_USER=
DEV_JIRA_PASS=

# L HOUSE 공장
LHOUSE_PMS_USER=
LHOUSE_PMS_PASS=
