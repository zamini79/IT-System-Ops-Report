# =============================================================================
# .dockerignore  —  프로젝트 루트 기준 (docker-compose.prod.yml build context)
# =============================================================================

# ── 의존성 (이미지 내에서 npm ci 로 재설치) ──────────────────────────────────────
**/node_modules

# ── 빌드 출력물 (이미지 내에서 재빌드) ──────────────────────────────────────────
**/dist
apps/frontend/.vite

# ── 런타임 데이터 (볼륨으로 관리) ────────────────────────────────────────────────
apps/backend/uploads/
apps/backend/outputs/

# ── 환경 변수 파일 (절대 이미지에 포함하지 말 것) ───────────────────────────────
.env
.env.*
!.env.prod.example

# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── 개발 도구 / 에디터 ───────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# ── 테스트 / 문서 ─────────────────────────────────────────────────────────────────
**/*.test.ts
**/*.spec.ts
**/__tests__/
**/coverage/

# ── Docker 파일 자체 (빌드 컨텍스트에 불필요) ────────────────────────────────────
docker-compose*.yml
**/Dockerfile
**/Dockerfile.*
