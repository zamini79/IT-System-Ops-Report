# =============================================================================
# SKBS IT Report — 환경 변수 예시
# 복사 후 실제 값으로 채워주세요: cp .env.example .env
#
# macOS Homebrew PostgreSQL 기준:
#   createdb skbs_it_report
#   psql -d skbs_it_report -f apps/backend/src/config/schema.sql
# =============================================================================


# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173


# ── Database (Homebrew PostgreSQL — 현재 맥 계정으로 접속) ────────────────────
# 형식: postgresql://[user]@[host]/[dbname]
# 로컬 소켓 연결은 user/password 생략 가능
DATABASE_URL=postgresql://localhost/skbs_it_report


# ── JWT ───────────────────────────────────────────────────────────────────────
# 생성 예시: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_random_string
JWT_REFRESH_SECRET=replace_with_another_64_byte_hex_random_string
JWT_EXPIRES_IN=15m


# ── File System ───────────────────────────────────────────────────────────────
# 업로드된 원본 파일 저장 경로
UPLOAD_DIR=uploads
# 생성된 PDF 보고서 저장 경로
OUTPUT_DIR=outputs
# 단일 파일 최대 크기 (MB)
MAX_FILE_SIZE_MB=50


# =============================================================================
# 시스템별 자격증명
# 각 사업부의 내부 시스템 접속 정보입니다.
# URL 끝에 슬래시(/)를 붙이지 마세요.
# =============================================================================


# ── BIO 사업부 ─────────────────────────────────────────────────────────────────

# eDMS (전자문서관리시스템)
BIO_EDMS_URL=https://edms.bio.internal
BIO_EDMS_USER=
BIO_EDMS_PASS=

# ELN (전자실험노트)
BIO_ELN_URL=https://eln.bio.internal
BIO_ELN_USER=
BIO_ELN_PASS=

# GCLP LIMS (실험실정보관리시스템)
